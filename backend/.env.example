# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required: your OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Model to use — swap to gpt-4o or gpt-5.6 when available on your account
OPENAI_MODEL=gpt-4o

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
# Directory where ChromaDB persists its vector index (relative to /backend)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=curriculum

# ─── Knowledge base ───────────────────────────────────────────────────────────
# Path to the /knowledge_base directory (relative to /backend)
KNOWLEDGE_BASE_DIR=../knowledge_base

# ─── Session storage ──────────────────────────────────────────────────────────
# SQLite database path for session persistence (relative to /backend)
DB_PATH=./sessions.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
